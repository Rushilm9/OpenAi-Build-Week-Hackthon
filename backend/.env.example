# Copy this file to .env for local development. Never commit real credentials.

# OpenAI model provider
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-5.6-sol
OPENAI_DISCOVERY_MODEL=gpt-5.6-terra
OPENAI_DISCOVERY_REASONING_EFFORT=low
OPENAI_ANALYSIS_REASONING_EFFORT=medium
OPENAI_DEEP_REASONING_EFFORT=high
OPENAI_REQUEST_TIMEOUT_SECONDS=60

# PostgreSQL / Supabase
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional financial-data providers
FRED_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ArthaVest/1.0

# Application
ENABLE_LOGS=true
DEPLOYED=false
PUBLIC_API_BASE_URL=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SAVE_RESULTS=false
ENABLE_DEV_ROUTES=false

# Optional Arize Phoenix observability and prompt management
ARIZE_ENABLED=false
ARIZE_MCP_ENABLED=false
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT_NAME=arthavest

# Discovery liquidity filters
DISCOVERY_HARD_MIN_MCAP=5000000000
DISCOVERY_HARD_MIN_AVG_VOL=500000
DISCOVERY_HARD_MIN_PRICE=50

# Market-data MCP service
MCP_SERVER_URL=https://quantai-mcp-server.onrender.com
MCP_TIMEOUT=45
MCP_RETRIES=2
MCP_HEALTH_TTL=15
DISABLE_MCP_FALLBACK=false
